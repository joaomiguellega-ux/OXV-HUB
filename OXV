-- ============================================================
-- QUICK ACTIONS PANEL  (floating, draggable, 7 buttons stacked)
-- ============================================================
do
    (function()
        local UIS = UserInputService
        local TS  = TweenService
        local RS  = RunService

        -- Theme: dark cards on transparent background, green accents
        local C_CARD     = Color3.fromRGB(14, 22, 30)
        local C_CARD_ON  = Color3.fromRGB(0, 195, 255)
        local C_TEXT     = Color3.fromRGB(220, 240, 255)
        local C_TEXT_ON  = Color3.fromRGB(0, 12, 22)
        local C_STROKE   = Color3.fromRGB(34, 64, 96)
        local C_GREEN    = Color3.fromRGB(0, 195, 255)
        local C_DOT      = Color3.fromRGB(34, 64, 96)

        -- Cleanup
        local pgQA = LP:WaitForChild("PlayerGui")
        local old = pgQA:FindFirstChild("OXVHubQuickActions")
        if old then old:Destroy() end

        local qaGui = Instance.new("ScreenGui")
        qaGui.Name = "OXVHubQuickActions"
        qaGui.ResetOnSpawn = false
        qaGui.IgnoreGuiInset = true
        qaGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        qaGui.DisplayOrder = 9
        qaGui.Parent = pgQA

        -- Expose hide/show function so the main window's X button can hide/show the panel
        _G.OXVHubQAHide = function(hide)
            qaGui.Enabled = not hide
        end

        local BTN = 58
        local GAP = 8
        -- 4 rows: row1=AUTO L/AUTO R, row2=AIMBOT/LAGGER, row3=DROP/TP DOWN, row4=CARRY (centered)
        local ROW_W = (BTN * 2) + GAP
        local NUM_ROWS = 4
        local PANEL_W = ROW_W
        local PANEL_H = (BTN * NUM_ROWS) + (GAP * (NUM_ROWS - 1))

        -- Outer transparent container = this is the ONLY thing that's draggable
        local panel = Instance.new("Frame", qaGui)
        panel.Name = "Panel"
        panel.Size = UDim2.new(0, PANEL_W, 0, PANEL_H)
        panel.AnchorPoint = Vector2.new(1, 0.5)
        panel.Position = UDim2.new(1, -20, 0.5, 0)  -- right-middle of screen by default
        panel.BackgroundTransparency = 1
        panel.BorderSizePixel = 0
        panel.ZIndex = 10
        panel.Active = true  -- enables drag input

        -- Drag: the user can drag the panel by clicking ANY empty space inside it.
        -- The buttons sit on top with their own ZIndex; they don't trigger drag
        -- because their own InputBegan consumes the click first.
        local dragging, dragStart, startPos = false, nil, nil
        panel.InputBegan:Connect(function(input)
            if State.uiLocked then return end  -- locked: no drag
            if input.UserInputType == Enum.UserInputType.MouseButton1
               or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = panel.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end)
        UIS.InputChanged:Connect(function(input)
            if State.uiLocked then return end  -- locked: no drag
            if not dragging then return end
            if input.UserInputType == Enum.UserInputType.MouseMovement
               or input.UserInputType == Enum.UserInputType.Touch then
                local delta = input.Position - dragStart
                panel.Position = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
            end
        end)

        local function tween(obj, time, props)
            return TS:Create(obj, TweenInfo.new(time, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props)
        end

        -- Build a single button at row/col grid position
        local function makeBtn(rowIdx, colIdx, label, onClick, isToggle)
            local x = (colIdx == 1) and 0 or (BTN + GAP)
            local y = (rowIdx - 1) * (BTN + GAP)

            local btn = Instance.new("TextButton", panel)
            btn.Size = UDim2.new(0, BTN, 0, BTN)
            btn.Position = UDim2.new(0, x, 0, y)
