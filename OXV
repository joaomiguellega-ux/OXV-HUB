-- ============================================================
-- TP DOWN (OXV Hub — instant raycast teleport to ground)
-- ============================================================
runTPDown = function()
    pcall(function()
        local c = LP.Character; if not c then return end
        local root = c:FindFirstChild("HumanoidRootPart"); if not root then return end
        local hum = c:FindFirstChildOfClass("Humanoid")

        local rp = RaycastParams.new()
        rp.FilterDescendantsInstances = {c}
        rp.FilterType = Enum.RaycastFilterType.Exclude

        local res = workspace:Raycast(root.Position, Vector3.new(0, -2000, 0), rp)
        if res then
            local hipHeight = (hum and hum.HipHeight) or 2
            local off = hipHeight + (root.Size.Y / 2) + 0.05
            -- Preserve XZ + look direction, only change Y
            local look = root.CFrame.LookVector
            local pos = Vector3.new(root.Position.X, res.Position.Y + off, root.Position.Z)
            root.CFrame = CFrame.new(pos, pos + Vector3.new(look.X, 0, look.Z))
            root.AssemblyLinearVelocity = Vector3.zero
        end
    end)
end

-- ============================================================
-- DROP BRAINROT (OXV Hub — controlled ascent + raycast land)
-- ============================================================
local DROP_ASCEND_DURATION = 0.22
local DROP_ASCEND_SPEED = 160
local _dropConn = nil
runDropBrainrot=function()
    -- If already running, ignore re-trigger (button will pulse anyway)
    if State.dropEnabled then return end
    local char = LP.Character; if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
    State.dropEnabled = true
    if stackBtnRefs.drop then stackBtnRefs.drop.setOn(true) end

    local t0 = tick()
    if _dropConn then pcall(function() _dropConn:Disconnect() end); _dropConn = nil end

    _dropConn = RunService.Heartbeat:Connect(function()
        local c = LP.Character
        local r = c and c:FindFirstChild("HumanoidRootPart")
        if not r then
            if _dropConn then _dropConn:Disconnect(); _dropConn = nil end
            State.dropEnabled = false
            if stackBtnRefs.drop then stackBtnRefs.drop.setOn(false) end
            return
        end
        if not State.dropEnabled then
            -- Externally stopped
            if _dropConn then _dropConn:Disconnect(); _dropConn = nil end
            if stackBtnRefs.drop then stackBtnRefs.drop.setOn(false) end
            return
        end
        if tick() - t0 >= DROP_ASCEND_DURATION then
            if _dropConn then _dropConn:Disconnect(); _dropConn = nil end
            -- Raycast down and snap to floor
            pcall(function()
                local rp = RaycastParams.new()
                rp.FilterDescendantsInstances = {c}
                rp.FilterType = Enum.RaycastFilterType.Exclude
                local rr = workspace:Raycast(r.Position, Vector3.new(0, -3000, 0), rp)
                if rr then
                    local hum = c:FindFirstChildOfClass("Humanoid")
                    local off = ((hum and hum.HipHeight) or 2) + (r.Size.Y / 2)
                    r.CFrame = CFrame.new(r.Position.X, rr.Position.Y + off, r.Position.Z)
                    r.AssemblyLinearVelocity = Vector3.zero
                end
            end)
            State.dropEnabled = false
            if stackBtnRefs.drop then stackBtnRefs.drop.setOn(false) end
            return
        end
        -- Ascend: keep pushing up so gravity doesn't win
        local lv = r.AssemblyLinearVelocity
        r.AssemblyLinearVelocity = Vector3.new(lv.X, DROP_ASCEND_SPEED, lv.Z)
    end)
end
stopDropBrainrot=function()
    State.dropEnabled = false
    if _dropConn then pcall(function() _dropConn:Disconnect() end); _dropConn = nil end
    if stackBtnRefs.drop then stackBtnRefs.drop.setOn(false) end
end

