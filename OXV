    bLbl.Font = Enum.Font.GothamBlack
    bLbl.TextSize = 12
    bLbl.TextXAlignment = Enum.TextXAlignment.Left

    -- Bottom hairline under banner
    local bDiv = Instance.new("Frame", banner)
    bDiv.Size = UDim2.new(1, -28, 0, 1)
    bDiv.Position = UDim2.new(0, 14, 1, -1)
    bDiv.BackgroundColor3 = C.divider
    bDiv.BackgroundTransparency = 0.4
    bDiv.BorderSizePixel = 0

    -- Page frame that holds the rows for this section
    local page = Instance.new("Frame", mainScroll)
    page.Name = tabName
    page.Size = UDim2.new(1, 0, 0, 0)
    page.AutomaticSize = Enum.AutomaticSize.Y
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.LayoutOrder = pageOrder * 1000 + 1
    page.Visible = true  -- always visible — single scroll

    local ll = Instance.new("UIListLayout", page)
    ll.SortOrder = Enum.SortOrder.LayoutOrder
    ll.Padding = UDim.new(0, 4)
    ll.HorizontalAlignment = Enum.HorizontalAlignment.Center

    tabPages[tabName] = page; currentPage = page; lo = 0
    buildFn()
    currentPage = nil
end

