local pageOrder = 0
local function buildPage(tabName, buildFn)
    pageOrder = pageOrder + 1

    -- Section header banner (replaces the tabs)
    local banner = Instance.new("Frame", mainScroll)
    banner.Name = "Banner_"..tabName
    banner.Size = UDim2.new(1, 0, 0, 40)
    banner.BackgroundColor3 = Color3.fromRGB(8, 18, 28)
    banner.BorderSizePixel = 0
    banner.LayoutOrder = pageOrder * 1000

    -- Thicker left accent strip
    local bAcc = Instance.new("Frame", banner)
    bAcc.Size = UDim2.new(0, 4, 0.55, 0)
    bAcc.Position = UDim2.new(0, 14, 0.225, 0)
    bAcc.BackgroundColor3 = C.accent
    bAcc.BorderSizePixel = 0
    mkCorner(bAcc, 2)

    local bLbl = Instance.new("TextLabel", banner)
    bLbl.Size = UDim2.new(1, -32, 1, 0)
    bLbl.Position = UDim2.new(0, 26, 0, 0)
    bLbl.BackgroundTransparency = 1
    bLbl.Text = tabName:upper()
