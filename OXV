            btn.BorderSizePixel = 0
            btn.ZIndex = 12
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 12)
            local btnStroke = Instance.new("UIStroke", btn)
            btnStroke.Thickness = 1
            btnStroke.Color = C_STROKE
            btnStroke.Transparency = 0.4

            local txt = Instance.new("TextLabel", btn)
            txt.Size = UDim2.new(1, -4, 1, -16)
            txt.Position = UDim2.new(0, 2, 0, 4)
            txt.BackgroundTransparency = 1
            txt.Text = label
            txt.TextColor3 = C_GREEN
            txt.Font = Enum.Font.GothamBlack
            txt.TextSize = 10
            txt.TextWrapped = true
            txt.TextXAlignment = Enum.TextXAlignment.Center
            txt.TextYAlignment = Enum.TextYAlignment.Center
            txt.ZIndex = 13

            -- Tiny status dot at bottom (like in the screenshot)
            local dot = Instance.new("Frame", btn)
            dot.Size = UDim2.new(0, 4, 0, 4)
            dot.Position = UDim2.new(0.5, -2, 1, -8)
            dot.BackgroundColor3 = C_DOT
            dot.BorderSizePixel = 0
            dot.ZIndex = 13
            Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

            local active = false
            local function setActive(on)
                active = on and true or false
                if active then
                    tween(btn, 0.1, { BackgroundColor3 = C_CARD_ON }):Play()
                    tween(txt, 0.1, { TextColor3 = C_TEXT_ON }):Play()
                    tween(btnStroke, 0.1, { Color = Color3.fromRGB(150, 220, 255), Transparency = 0.1 }):Play()
                    tween(dot, 0.1, { BackgroundColor3 = Color3.fromRGB(255, 255, 255) }):Play()
                else
                    tween(btn, 0.1, { BackgroundColor3 = C_CARD }):Play()
                    tween(txt, 0.1, { TextColor3 = C_GREEN }):Play()
                    tween(btnStroke, 0.1, { Color = C_STROKE, Transparency = 0.4 }):Play()
                    tween(dot, 0.1, { BackgroundColor3 = C_DOT }):Play()
                end
            end

            local function flashAction()
                tween(btn, 0.05, { BackgroundColor3 = C_CARD_ON }):Play()
                tween(txt, 0.05, { TextColor3 = C_TEXT_ON }):Play()
                task.delay(0.18, function()
                    if not btn.Parent then return end
                    tween(btn, 0.12, { BackgroundColor3 = C_CARD }):Play()
                    tween(txt, 0.12, { TextColor3 = C_GREEN }):Play()
                end)
            end

            -- Track press start to distinguish tap from drag
            local pressX, pressY, pressTime = 0, 0, 0
            btn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                   or input.UserInputType == Enum.UserInputType.Touch then
                    pressX = input.Position.X
                    pressY = input.Position.Y
                    pressTime = tick()
                end
            end)
            btn.InputEnded:Connect(function(input)
                if input.UserInputType ~= Enum.UserInputType.MouseButton1
                   and input.UserInputType ~= Enum.UserInputType.Touch then return end
                local dx = math.abs(input.Position.X - pressX)
                local dy = math.abs(input.Position.Y - pressY)
                local dt = tick() - pressTime
                -- Only fire if user didn't drag (less than 6px movement) and didn't hold too long
                if dx < 6 and dy < 6 and dt < 0.5 then
                    if isToggle then
                        setActive(not active)
                    else
                        flashAction()
                    end
                    task.spawn(function()
                        local ok, err = pcall(function() onClick(active) end)
                        if not ok then warn("[OXVHubQA] " .. label .. " error: " .. tostring(err)) end
