                tween(carryTxt, 0.1, { TextColor3 = C_GREEN }):Play()
                tween(carryStroke, 0.1, { Color = C_STROKE, Transparency = 0.4 }):Play()
                tween(carryDot, 0.1, { BackgroundColor3 = C_DOT }):Play()
            end
        end

        local cPressX, cPressY, cPressTime = 0, 0, 0
        carryBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
               or input.UserInputType == Enum.UserInputType.Touch then
                cPressX = input.Position.X; cPressY = input.Position.Y; cPressTime = tick()
            end
        end)
        carryBtn.InputEnded:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
               and input.UserInputType ~= Enum.UserInputType.Touch then return end
            if math.abs(input.Position.X - cPressX) < 6 and math.abs(input.Position.Y - cPressY) < 6 and tick() - cPressTime < 0.5 then
                setCarryQA(not carryActive)
                State.speedToggled = carryActive
                if carryActive and State.laggerEnabled then
                    State.laggerEnabled = false
                    if stackBtnRefs.lagger then stackBtnRefs.lagger.setOn(false) end
                end
                if stackBtnRefs.carrySpeed then stackBtnRefs.carrySpeed.setOn(carryActive) end
            end
        end)

        -- Periodic sync with the main UI state
        task.spawn(function()
            while qaGui.Parent do
                pcall(function()
                    setBatAimbotQA(State.batAimbotToggled or false)
                    setAutoLeftQA(State.autoLeftEnabled or false)
                    setAutoRightQA(State.autoRightEnabled or false)
                    setLaggerQA(State.laggerEnabled or false)
                    setCarryQA(State.speedToggled or false)
                end)
                task.wait(0.3)
            end
        end)
    end)()
end


